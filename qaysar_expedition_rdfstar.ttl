	 :creator ga:MarekGawecki ; 
	 :confidence "1.0"^^xsd:decimal .

<< ga:EWA76_MG94 :description "Vier Aufnahmen von Werkzeugen und Geräten aus der Werkstatt eines Gold- und Silberschmieds aus Qaysar."@de >> 
