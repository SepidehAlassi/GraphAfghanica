# --- The Resulting Object ---

ga:EWA76_MG65
    a :Image ;
    :classification ga:Women ;
    :hasDigitalRepresentation <https://example.org/images/photo1.jpg> ;
    :belongsTo ga:EWA76_Collection ;
    crm:P108i_was_produced_by ga:EWA76_Production_Qayser ;
    :description "Near the concrete pillars for the new bazaar, other farmers are offering their sheep's wool fleeces..."@en .

# --- AI & Provenance Meta-modeling via RDF-star ---

