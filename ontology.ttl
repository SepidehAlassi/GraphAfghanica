@prefix crm: <http://www.cidoc-crm.org/cidoc-crm/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix wdt: <http://www.wikidata.org/entity/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix schema: <http://schema.org/> .
@prefix : <http://www.graphAfghanica.org/ontology/> .

# ==========================================
# Classes
# ==========================================

:Image
    a rdfs:Class ;
    rdfs:subClassOf crm:E36_Visual_Item .
:Person
    a rdfs:Class ;
    rdfs:subClassOf crm:E21_Person ;
    owl:equivalentClass foaf:Person .

:AI_Model
    a rdfs:Class ;
    rdfs:label "An AI model" .

# ==========================================
# Properties
# ==========================================

:classification
    a rdf:Property ;
    rdfs:domain :Image ;
    rdfs:range skos:Concept .

:description
    a rdf:Property ;
    rdfs:subPropertyOf crm:P3_has_note ;
    rdfs:domain :Image .

:hasDigitalRepresentation
    a rdf:Property ;
    rdfs:domain :Image ;
    rdfs:range xsd:anyURI .

:belongsTo
    a rdf:Property ;
    rdfs:comment "Connects an image to its curated collection" ;
    rdfs:domain :Image ;
    rdfs:range crm:E78_Curated_Holding .

:model
    a rdf:Property ;
    rdfs:domain rdf:Statement ;
    rdfs:range :AI_Model ;
    rdfs:label "AI model used"@en .

:confidence
    a rdf:Property ;
    rdfs:domain rdf:Statement ;
    rdfs:range xsd:decimal .

:creator
    a rdf:Property ;
    rdfs:domain rdf:Statement ;
    rdfs:label "creator"@en ;
    rdfs:comment "Annotates a statement with its creator" .

# ==========================================
# Resources & Instances
# ==========================================

:ImageTaxonomy
    a skos:ConceptScheme ;
    skos:hasTopConcept :People , :Landscape , :Urban .

:People a skos:Concept ;
    skos:inScheme :ImageTaxonomy ;
    skos:prefLabel "People"@en ;
    skos:narrower :Women .

:Women a skos:Concept ;
    skos:inScheme :ImageTaxonomy ;
    skos:prefLabel "Women"@en ;
    skos:broader :People .

:Landscape a skos:Concept ;
    skos:inScheme :ImageTaxonomy ;
    skos:prefLabel "Landscape"@en .

:Urban a skos:Concept ;
    skos:inScheme :ImageTaxonomy ;
    skos:prefLabel "Urban"@en .

# --- Expedition Context ---

:Expedition_EWA76_Afghanistan
    a crm:E7_Activity ;
    rdfs:label "Polish Ethnological Asian Expedition 1976 (EWA-76)" ;
    crm:P14_carried_out_by :PoznanEthnography ;
    crm:P7_took_place_at :Afghanistan ;
    crm:P4_has_time-span :TimeSpan_EWA76 ;
    crm:P9_consists_of :Expedition_EWA76_Herat_Visit ,
                       :Expedition_EWA76_Herat_to_Kandahar_Visit ,
                       :Expedition_EWA76_Kandahar_Visit ,
                       :Expedition_EWA76_Ghazni_Visit ,
                       :Expedition_EWA76_Kabul_Visit ,
                       :Expedition_EWA76_Nayak_Visit ,
                       :Expedition_EWA76_TalaOBarfak_Visit ,
                       :Expedition_EWA76_Dawlatabad_Visit ,
                       :Expedition_EWA76_Qaysar_Visit ,
                       :Expedition_EWA76_MazarSharif_Visit ,
                       :Expedition_EWA76_Jalalabad_Visit .

:Afghanistan
    a crm:E53_Place ;
    crm:P1_is_identified_by :Afghanistan_name ;
    owl:sameAs wdt:Q889 .

:Afghanistan_name
    a crm:E44_Place_Appellation ;
    crm:P190_has_symbolic_content "Afghanistan" .

:TimeSpan_EWA76
    a crm:E52_Time-Span ;
    crm:P82a_begin_of_the_begin "1976-05-08"^^xsd:date ;
    crm:P82b_end_of_the_end "1976-10-03"^^xsd:date .

:MarekGawecki
    a :Person ;
    schema:givenName "Mark" ;
    schema:familyName "Gawęcki" ;
    schema:name "Mark Gawęcki" .

:PoznanEthnography
    a crm:E74_Group ;
    rdfs:label "Poznan Ethnology Department" ;
    crm:P107_has_current_or_former_member :MarekGawecki .

# --- Collection Context ---

:EWA76_Collection
   a crm:E78_Curated_Holding ;
   crm:P1_is_identified_by "EWA76 Photo Collection" .

