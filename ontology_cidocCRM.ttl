# Time-Spans for Sub-Activities
# ======================================================


ga:TimeSpan_EWA76_Qaysar a crm:E52_Time-Span ;
    crm:P82a_begin_of_the_begin "1976-08-08"^^xsd:date ;
    crm:P82b_end_of_the_end "1976-08-21"^^xsd:date .

ga:TimeSpan_EWA76_Almar a crm:E52_Time-Span ;
    crm:P82a_begin_of_the_begin "1976-08-08"^^xsd:date ;
    crm:P82b_end_of_the_end "1976-08-08"^^xsd:date .

# ======================================================
# Expedition Sub-Activities
# ======================================================

ga:Expedition_EWA76_Qaysar_Visit
    a crm:E7_Activity ;
    crm:P1_is_identified_by ga:Expedition_EWA76_Qaysar_Visit_Name ;
    crm:P14_carried_out_by ga:PoznanEthnography ;
    crm:P7_took_place_at ga:Qaysar ;
    crm:P4_has_time-span ga:TimeSpan_EWA76_Qaysar .

ga:Expedition_EWA76_Qaysar_Visit_Name a crm:E41_Appellation ;
    crm:P190_has_symbolic_content "EWA-76 visit to Qaysar" .

# ======================================================
# Production Context: Photo-taking
# ======================================================

ga:EWA76_Almar_Photography
    a crm:E12_Production ;
    crm:P14_carried_out_by ga:MarekGawecki ;
    crm:P9i_forms_part_of ga:Expedition_EWA76_Qaysar_Visit ;
    crm:P7_took_place_at ga:Almar ;
    crm:P4_has_time-span ga:TimeSpan_EWA76_Almar .

# ======================================================
# Resulting Photograph Object
# ======================================================

ga:EWA76_MG69
    a crm:E22_Human-Made_Object ;
    crm:P2_has_type ga:Photograph_Type ;
    crm:P102_has_title ga:EWA76_MG69_Title ;
    crm:P3_has_note "MG69 Alter Basar in Almar" ;
    crm:P46i_forms_part_of ga:EWA76_Collection ;
    crm:P108i_was_produced_by ga:EWA76_Almar_Photography ;
    crm:P128_carries ga:EWA76_MG69_DigitalFile ;
    crm:P43_has_dimension ga:EWA76_MG69_Quality ,
                          ga:EWA76_MG69_Width ,
                          ga:EWA76_MG69_Height .

ga:EWA76_MG69_Title
    a crm:E35_Title ;
    crm:P190_has_symbolic_content "Basar in Almar" .

ga:EWA76_MG69_Quality
    a crm:E54_Dimension ;
    crm:P2_has_type ga:Image_Quality ;
    crm:P90_has_value "sehr gut" .

ga:EWA76_MG69_Width
    a crm:E54_Dimension ;
    crm:P2_has_type ga:Width ;
    crm:P90_has_value 175 ;
    crm:P91_has_unit ga:Millimeters .

ga:EWA76_MG69_Height
    a crm:E54_Dimension ;
    crm:P2_has_type ga:Height ;
    crm:P90_has_value 120 ;
    crm:P91_has_unit ga:Millimeters .

# ======================================================
# Digital File as Information Object
# ======================================================

ga:EWA76_MG69_DigitalFile
    a crm:E73_Information_Object ;
    crm:P1_is_identified_by ga:EWA76_MG69_DigitalFile_URI ;
    crm:P3_has_note "Digital image file representing photograph EWA76_MG69." .

ga:EWA76_MG69_DigitalFile_URI
    a crm:E42_Identifier ;
    crm:P190_has_symbolic_content "https://EWA76.org/images/IMG69.jpg" .

# ======================================================
# Description with Provenance
# ======================================================

ga:EWA76_MG69_Description_en
    a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG69 ;
    crm:P190_has_symbolic_content "In the old part of the Almar bazaar, the dukanha (shops) which are open to the street are still traditionally made of clay. Bast mats protect against the strong sunlight. In the foreground, a porter in typical padded and tattered working clothes sits in the shade of a pine tree on the street. He wraps the rope on his back around the load and guides it over his forehead, which is also padded, when he is leaning forward carrying a load of up to 100 kg." ;
    crm:P2_has_type ga:Image_Description_Type .

ga:Image_Description_Type
    a crm:E55_Type ;
    crm:P190_has_symbolic_content "Image Description" .

ga:EWA76_MG69_Description_en_Creation
    a crm:E65_Creation ;
    crm:P94_has_created ga:EWA76_MG69_Description_en ;
    crm:P14_carried_out_by ga:MarekGawecki ;
    crm:P43_has_dimension ga:EWA76_MG69_Description_en_Confidence .

ga:EWA76_MG69_Description_en_Confidence
    a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

# ======================================================
# AI Model and Classification as Attribute Assignment
# ======================================================

ga:Pytorch_classifier_v2
    a crm:E39_Actor ;
    crm:P2_has_type ga:Artificial_Intelligence_Model ;
    crm:P1_is_identified_by ga:Pytorch_classifier_v2_Name .

ga:Pytorch_classifier_v2_Name
    a crm:E41_Appellation ;
    crm:P190_has_symbolic_content "PyTorch ResNet-50 Classifier v2.0" .

ga:EWA76_MG69_Classification
    a crm:E13_Attribute_Assignment ;
    crm:P14_carried_out_by ga:Pytorch_classifier_v2 ;
    crm:P140_assigned_attribute_to ga:EWA76_MG69 ;
    crm:P141_assigned ga:Urban ;
    crm:P177_assigned_property_type crm:P2_has_type ;
    crm:P43_has_dimension ga:EWA76_MG69_Classification_Confidence .

ga:EWA76_MG69_Classification_Confidence
    a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 0.89 ;
    crm:P91_has_unit ga:Probability_Unit .
