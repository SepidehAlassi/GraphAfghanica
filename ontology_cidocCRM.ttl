# ======================================================
# Strict CIDOC CRM version
# Only CIDOC CRM classes/properties are used for modeling.
# ======================================================

# ======================================================
# Types and Units
# ======================================================

ga:Photograph_Type
    a crm:E55_Type ;
    crm:P190_has_symbolic_content "Photograph" .

ga:Urban
    a crm:E55_Type ;
    crm:P190_has_symbolic_content "Urban" .

ga:Women
    a crm:E55_Type ;
    crm:P190_has_symbolic_content "Women" .

ga:People a crm:E55_Type ;
    crm:P190_has_symbolic_content "People" .

ga:Landscape a crm:E55_Type ;
    crm:P190_has_symbolic_content "Landscape" .

ga:Artificial_Intelligence_Model
    a crm:E55_Type ;
    crm:P190_has_symbolic_content "Artificial Intelligence Model" .

ga:Confidence
    a crm:E55_Type ;
    crm:P190_has_symbolic_content "Confidence Score" .

ga:Image_Quality
    a crm:E55_Type ;
    crm:P190_has_symbolic_content "Image quality" .

ga:Width
    a crm:E55_Type ;
    crm:P190_has_symbolic_content "Width" .

ga:Height
    a crm:E55_Type ;
    crm:P190_has_symbolic_content "Height" .

ga:Millimeters
    a crm:E58_Measurement_Unit ;
    crm:P190_has_symbolic_content "Millimeters" .

ga:Probability_Unit
    a crm:E58_Measurement_Unit ;
    crm:P190_has_symbolic_content "Probability value between 0 and 1" .

ga:Bibliographic_Reference_Type a crm:E55_Type ;
    crm:P190_has_symbolic_content "Bibliographic Reference" .

# ======================================================
# Expedition Context
# ======================================================

ga:Expedition_EWA76_Afghanistan
    a crm:E7_Activity ;
    crm:P1_is_identified_by ga:Expedition_EWA76_Afghanistan_Name ;
    crm:P14_carried_out_by ga:PoznanEthnography ;
    crm:P7_took_place_at ga:Afghanistan ;
    crm:P4_has_time-span ga:TimeSpan_EWA76 ;
    crm:P9_consists_of ga:Expedition_EWA76_Qaysar_Visit .

ga:Expedition_EWA76_Afghanistan_Name
    a crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Polish Ethnological Asian Expedition 1976 (EWA-76)" .

ga:TimeSpan_EWA76
    a crm:E52_Time-Span ;
    crm:P82a_begin_of_the_begin "1976-05-08"^^xsd:date ;
    crm:P82b_end_of_the_end "1976-10-03"^^xsd:date .

ga:MarekGawecki
    a crm:E21_Person ;
    crm:P1_is_identified_by ga:MarekGawecki_Name .

ga:MarekGawecki_Name
    a crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Marek Gawęcki" .

ga:PoznanEthnography
    a crm:E74_Group ;
    crm:P1_is_identified_by ga:PoznanEthnography_Name ;
    crm:P107_has_current_or_former_member ga:MarekGawecki .

ga:PoznanEthnography_Name
    a crm:E41_Appellation ;
    crm:P190_has_symbolic_content "Poznań Ethnology Department" .

# ======================================================
# Collection Context
# ======================================================

ga:EWA76_Collection
    a crm:E78_Curated_Holding ;
    crm:P1_is_identified_by ga:EWA76_Collection_Name .

ga:EWA76_Collection_Name
    a crm:E41_Appellation ;
    crm:P190_has_symbolic_content "EWA76 Photo Collection" .

# ======================================================
# Places
# ======================================================
ga:Afghanistan
    a crm:E53_Place ;
    crm:P1_is_identified_by ga:Afghanistan_Name .

ga:Afghanistan_Name
    a crm:E44_Place_Appellation ;
    crm:P190_has_symbolic_content "Afghanistan" .

ga:Qaysar a crm:E53_Place ;
          crm:P1_is_identified_by ga:Qaysar_Name .
ga:Qaysar_Name a crm:E44_Place_Appellation ;
          crm:P190_has_symbolic_content "Qaysar" .

ga:Almar a crm:E53_Place ;
        crm:P1_is_identified_by ga:Almar_Name .
ga:Almar_Name a crm:E44_Place_Appellation ;
        crm:P190_has_symbolic_content "Almar" .

