ga:EWA76_MG78_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG78 ;
    crm:P190_has_symbolic_content "Vor seiner Werkstatt im Basar von Almar präsentiert ein Möbelschreiner zwei seiner Arbeiten: eine Truhe mit reich bemalter Frontpartie und einen ebenfalls bemalten Ständer für Petrol- oder Benzin-Lampen. Ob bei der Truhe der Deckel oder die Frontfelder geöffnet werden können, ist nicht ersichtlich. Ähnlich bemalte Truhen und andere Gegenstände sind auf MG 89 zu sehen. Der Mann trägt einen ungefütterten uzbekischen Sommer-chapan aus gestreifter Baumwolle."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG78_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG78_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG78 ;
    crm:P190_has_symbolic_content "In front of his workshop in the bazaar of Almar, a cabinetmaker presents two of his works: a chest with a richly painted front and a stand for kerosen or petrol lamps, also painted. It is not clear whether the lid or the front panels of the chest can be opened. Similarly painted chests and other items can be seen on MG 89. The man wears an unlined Uzbek summer chapan made of striped cotton."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG78_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG78_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG78 ;
    crm:P190_has_symbolic_content "Przed swoim warsztatem na bazarze w Almar stolarz prezentuje dwie swoje prace: skrzynię z bogato malowanym frontem oraz stojak na lampy Pertol lub benzynowe, również malowane. Nie jest jasne, czy pokrywę lub przednie panele skrzyni można otworzyć. Podobnie pomalowane skrzynie i inne przedmioty można zobaczyć na MG 89. Mężczyzna ma na sobie uzbecki letni czapan bez podszewki wykonany z bawełny w paski."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG78_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

