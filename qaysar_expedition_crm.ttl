ga:EWA76_MG83_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG83 ;
    crm:P190_has_symbolic_content "Dieser turkmenische Stoffhändler verwendet einen traditionellen ‘Taschenrechner’, einen Abakus mit Holzperlen, die auf Metallstäben aufgereiht sind. Damit konnten afghanische Händler mit erstaunlicher Geschwindigkeit addieren und multiplizieren. Heute wird auch in den abgelegensten Dörfern mit dem Mobiltelefon gerechnet."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG83_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG83_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG83 ;
    crm:P190_has_symbolic_content "This Turkmen cloth merchant uses a traditional 'calculator', an abacus with wooden beads strung on metal rods. This allowed Afghan traders to add and multiply with astonishing speed. Today, even in the most remote villages, mobile phones are used instead."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG83_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG83_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG83 ;
    crm:P190_has_symbolic_content "Ten turkmeński handlarz suknem posługuje się tradycyjnym \"kalkulatorem\", liczydłem z drewnianymi paciorkami nawleczonymi na metalowe pręty. Pozwoliło to afgańskim handlarzom dodawać i mnożyć z zadziwiającą szybkością. Dziś nawet w najbardziej odległych wioskach używa się telefonów komórkowych."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG83_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

