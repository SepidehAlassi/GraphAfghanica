ga:EWA76_MG99_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG99 ;
    crm:P190_has_symbolic_content "Another blacksmith – with numerous spectators in the background. He, too, has rammed a small anvil into the ground and scattered his tools around him, ready to hand. However, it is not clear what he is currently working on. Between his feet, he holds something as if in a vice. Maybe he's forging nails to fix a wooden handle in the grommet of the four-pronged pitchfork in front of him?"@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG99_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG99_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG99 ;
    crm:P190_has_symbolic_content "Another blacksmith – with numerous spectators in the background. He, too, has rammed a small anvil into the ground and scattered his tools around him, ready to hand. However, it is not clear what he is currently working on. Between his feet, he holds something as if in a vice. Maybe he's forging nails to fix a wooden handle in the grommet of the four-pronged pitchfork in front of him?"@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG99_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG99_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG99 ;
    crm:P190_has_symbolic_content "Kolejny kowal – z licznymi widzami w tle. On również wbił w ziemię małe kowadło i rozrzucił wokół siebie narzędzia, gotowe do ręki. Nie jest jednak jasne, nad czym obecnie pracuje. Między stopami trzyma coś jakby w imadle. Może wykuwa gwoździe, żeby zamocować drewnianą rączkę w dziobku czterozębnych wideł przed sobą?"@pl ;
    crm:P2_has_type ga:Image_Description_Type .

