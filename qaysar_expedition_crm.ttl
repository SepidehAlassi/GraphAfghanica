ga:EWA76_MG74_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG74 ;
    crm:P190_has_symbolic_content "Eine weitere Aufnahme vom Markttag in Almar. Je nach Bedeutung einer Ortschaft finden ein oder zwei Markttage/Woche statt. Benachbarte Orte halten ihre Markttage an unterschiedlichen Wochentagen ab. Dadurch können Händler ihre Waren an verschiedenen Orten anbieten. Im Zentrum der Aufnahme stehen zwei Bettstellen (charpoi = Vierfuss). Dahinter ist ein teilweise überdeckter Abwasserkanal zu erkennen, der zwischen der Strasse und dem Fussgängerbereich vor den Läden verläuft."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG74_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG74_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG74 ;
    crm:P190_has_symbolic_content "are one or two market days per week. Neighbouring towns hold their market days on different days of the week. This allows merchants to offer their goods in different locations. In the centre of the photograph are two bedsteads (charpoi = four-foot). Behind it, a partially covered sewer can be seen, which runs between the street and the pedestrian area in front of the shops."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG74_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG74_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG74 ;
    crm:P190_has_symbolic_content "Kolejne ujęcie z dnia targowego w Almar. W zależności od znaczenia miejscowości, w tygodniu odbywa się jeden lub dwa dni targowe. W sąsiednich miastach dni targowe odbywają się w różne dni tygodnia. Dzięki temu sprzedawcy mogą oferować swoje towary w różnych lokalizacjach. W centrum nagrania znajdują się dwa łóżka (charpoi = czworonożne). Za nim widać częściowo zakryty kanał, który biegnie między ulicą a deptakiem przed sklepami."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG74_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
