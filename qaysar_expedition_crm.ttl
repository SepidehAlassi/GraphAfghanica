ga:EWA76_MG80_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG80 ;
    crm:P190_has_symbolic_content "Dieser Händler bewahrt einen gefährlich grossen Bestand von Zündhölzern in seinem dukan (Laden) auf. Von der Decke hängen weisse Baumwoll-‘Gürtel’, die in den Hohlsaum der weiten Pluderhosen eingezogen werden. Zwei schön bestickte taken (Schädelkappen) hat er von einer Frau in Kommission genommen. Hinter seinem Kopf hängen zwei Spiegel, die es ihm ermöglichen, seine Ware auch im Blick zu behalten, wenn er sich umdreht."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG80_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG80_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG80 ;
    crm:P190_has_symbolic_content "This merchant keeps a dangerously large stock of matches in his dukan (shop). White cotton 'belts' hang from the ceiling, which are pulled into the hemstitch of the wide harem trousers. He took two beautifully embroidered skull caps (taken) from a woman on commission. Behind his head hang two mirrors that allow him to keep an eye on his goods even when he turns around."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG80_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG80_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG80 ;
    crm:P190_has_symbolic_content "Kupiec ten trzyma w swoim dukan (sklepie) niebezpiecznie duży zapas zapałek. Z sufitu zwisają białe bawełniane \"paski\", które są wciągnięte w mereżkę szerokich spodni haremowych. Wziął dwie pięknie haftowane czapki z czaszką od kobiety na zlecenie. Za jego głową wiszą dwa lustra, które pozwalają mu mieć oko na swój towar nawet wtedy, gdy się odwróci"@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG80_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

