ga:EWA76_MG70_Classification_001_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG70_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG70 ;
    crm:P190_has_symbolic_content "Im moderneren Teil des Basars von Almar sind die Läden und Werkstätten ebenerdig und können zur Strasse abgeschlossen werden. Die Waren werden häufig, wie bei diesem Töpfer und dem danebenliegenden Dieselöl-Händler, vor dem Laden aufgestellt. Auf der Strasse trägt ein Mann zwei mit Tüchern zugedeckte Eimer. Sie enthalten vermutlich mast (Yoghurt) oder Frischkäse (panir-e kham)."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG70_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG70_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG70 ;
    crm:P190_has_symbolic_content "In the more modern part of the Almar bazaar, the shops and workshops are at ground level and can be closed off from the street. The goods are often placed in front of the shop, as in the case of this potter and the diesel oil merchant next door. On the street, a man carries two buckets covered with cloths. They probably contain mast (yoghurt) or cottage cheese (panir-e kham)."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG70_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG70_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG70 ;
    crm:P190_has_symbolic_content "W nowocześniejszej części bazaru Almar sklepy i warsztaty znajdują się na parterze i można je odgrodzić od ulicy. Towar jest często umieszczany przed sklepem, jak w przypadku tego garncarza i sprzedawcy oleju napędowego obok. Na ulicy mężczyzna niesie dwa wiadra przykryte. Prawdopodobnie zawierają mast (jogurt) lub serek śmietankowy (panir-e kham)."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG70_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

