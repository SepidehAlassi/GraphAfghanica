ga:EWA76_MG72_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG72 ;
    crm:P190_has_symbolic_content "This picture was taken just a few steps away from MG 71. In the foreground, the black water buckets, which have been made from defective hoses of truck wheels, dominate. Water jugs, flour sieves, rope goods and much more are offered here by traders who are only present on market day and do not have their own shop."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG72_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
