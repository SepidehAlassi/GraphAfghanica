ga:EWA76_MG71_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG71 ;
    crm:P190_has_symbolic_content "Der neue Basar wurde um den Verkehrs-Kreisel im Zentrum der alaqadari (Distrikthauptort) Almar angelegt. Die Händler/Handwerker, die am Strassenrand ihre Ware unter improvisierten Sonnenschirmen anbieten, kommen nur an den Markttagen aus der Umgebung in die Stadt."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG71_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG71_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG71 ;
    crm:P190_has_symbolic_content "The new bazaar was built around the roundabout in the center of the alaqadari (district capital) Almar. The traders/craftsmen who offer their goods under improvised parasols on the roadside only come to the city from the surrounding area on market days."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG71_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG71_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG71 ;
    crm:P190_has_symbolic_content "Nowy bazar został zbudowany wokół ronda w centrum alaqadari (stolicy dystryktu) Almar. Handlarze/rzemieślnicy, którzy oferują swoje towary pod zaimprowizowanymi parasolami na poboczu drogi, przyjeżdżają do miasta z okolic tylko w dni targowe."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG71_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

