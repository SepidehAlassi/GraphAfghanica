ga:EWA76_MG91_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG91 ;
    crm:P190_has_symbolic_content "Ein Zahnarzt hat seine Praxis am Strassenrand eingerichtet. Neben dem Zähneziehen scheint er auch Gebiss-Prothesen anzupassen. Auf der Abdeckung des Abwasser-Kanals im Hintergrund liegen Stapel von Altkleidern und gefaltete Baumwoll-chapane, in der Art, wie der Patient des Zahnarztes einen über seinen Schultern hängen hat. Die Ärmel sind viel zu lang; manchmal werden sie auf dem Rücken fixiert oder man kann sie auch als Taschen verwenden."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG91_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG91_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG91 ;
    crm:P190_has_symbolic_content "A dentist has set up his practice on the side of the road. In addition to extracting teeth, he also seems to be adapting dentures. On the cover of the sewer in the background are piles of old clothes and folded cotton chapans, like the one the dentist's patient has hanging over his shoulders. The sleeves are way too long; sometimes they are fixed on the back or you can also use them as bags."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG91_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG91_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG91 ;
    crm:P190_has_symbolic_content "Dentysta założył swój gabinet na poboczu drogi. Wydaje się, że oprócz wyrywania zębów zajmuje się również adaptacją protez. Na pokrywie kanału w tle leżą sterty starych ubrań i złożony bawełniany chapan, tak jak pacjent dentysty ma go zawieszonego na ramionach. Rękawy są zdecydowanie za długie; Czasami są mocowane z tyłu lub można ich również używać jako toreb."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG91_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

