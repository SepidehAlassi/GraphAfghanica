ga:EWA76_MG72_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG72 ;
    crm:P190_has_symbolic_content "To zdjęcie zostało zrobione zaledwie kilka kroków od MG 71. Na pierwszym planie dominują czarne wiadra na wodę, które zostały wykonane z uszkodzonych węży kół ciężarówek. Dzbanki na wodę, sita do mąki, wyroby linowe i wiele innych oferują tu handlarze, którzy są obecni tylko w dzień targowy i nie mają własnego sklepu."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG72_Description_pl_Confidence a crm:E54_Dimension ;
