ga:EWA76_MG73_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG73 ;
    crm:P190_has_symbolic_content "Am Strassenrand im modernen Basar, der um den zentralen Verkehrs-Kreisel erstellt wurde, sitzt ein Handwerker vor einem in die Erde gerammten kleinen Amboss, neben dem eine Heugabel und ein afghanisches Vorhängeschloss liegen. Daneben steht eine mit Rondellen verzierte Kanne. Zwischen seinen Füssen liegen grobe Werkzeuge im Staub. Er scheint für seinen neben ihm sitzenden Kunden etwas zu bearbeiten."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG73_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG73_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG73 ;
    crm:P190_has_symbolic_content "On the side of the road in the modern bazaar built around the central roundabout, a craftsman sits in front of a small anvil rammed into the earth, next to which lie a pitchfork and an Afghan padlock. Next to it is a jug decorated with roundels. Between his feet lie coarse tools in the dust. He seems to be working on something for his client sitting next to him."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG73_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG73_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG73 ;
    crm:P190_has_symbolic_content "Na poboczu drogi na nowoczesnym bazarze zbudowanym wokół centralnego ronda rzemieślnik siedzi przed małym kowadłem wbitym w ziemię, obok którego leżą widły i afgańska kłódka. Obok znajduje się dzbanek ozdobiony roundelami. Między jego stopami leżą w kurzu grube narzędzia. Wygląda na to, że pracuje nad czymś dla swojego klienta siedzącego obok."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG73_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

