ga:EWA76_MG72_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG72 ;
    crm:P190_has_symbolic_content "Dieses Bild ist nur wenige Schritte entfernt von MG 71 aufgenommen worden. Im Vordergrund dominieren die schwarzen Wassereimer, die aus defekten Schläuchen von Lastwagenrädern hergestellt worden sind. Wasserkannen, Mehlsiebe, Seilerwaren und vieles mehr wird hier von Händlern angeboten, die nur am Markttag anwesend sind und keinen eigenen Laden besitzen."@de ;
    crm:P2_has_type ga:Image_Description_Type .

