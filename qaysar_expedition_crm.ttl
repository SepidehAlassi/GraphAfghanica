ga:EWA76_MG92_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG92 ;
    crm:P190_has_symbolic_content "Ein älterer Paschtune schärft eine Schere an einem Schleifstein. Mit einem Pedal wird ein grosses Schwungrad angetrieben, das über einen Riemen den Schleifstein in Drehung versetzt. Besonders scharfe Scheren werden für das Scheren des Flors von frisch geknüpften Teppichen benötigt (siehe MG 87 und 88)."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG92_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG92_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG92 ;
    crm:P190_has_symbolic_content "An elderly Pashtun sharpens a pair of scissors on a whetstone. A large flywheel is driven by a pedal, which rotates the grindstone via a belt. Particularly sharp scissors are needed for shearing the pile of freshly knotted carpets (see MG 87 and 88)."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG92_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG92_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG92 ;
    crm:P190_has_symbolic_content "Starszy Pasztun ostrzy nożyczki na osełce. Duże koło zamachowe jest napędzane pedałem, który obraca kamień szlifierski za pomocą paska. Szczególnie ostre nożyczki są potrzebne do strzyżenia stosu świeżo zawiązanych dywanów (patrz MG 87 i 88)."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG92_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

