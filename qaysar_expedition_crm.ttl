ga:EWA76_MG93_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG93 ;
    crm:P190_has_symbolic_content "Ein Schmied hat seinen Arbeitsplatz auf dem Wochenmarkt in Qaysar eingerichtet. Vor ihm steckt ein kleiner Amboss in der Erde. Daneben liegen seine Werkzeuge und am unteren Bildrand ist die Esse zu sehen, in der Holzkohle zwischen zwei senkrecht gestellten Steinplatten mit zwei Blasebälgen zum Glühen gebracht wird. Dieser Schmied scheint hauptsächlich Sicheln und Hufeisen herzustellen."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG93_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG93_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG93 ;
    crm:P190_has_symbolic_content "A blacksmith has set up his workplace at the weekly market in Qaysar. In front of him is a small anvil stuck in the earth. Next to it are his tools and at the bottom of the picture you can see the forge in which charcoal is made to glow with two bellows. He seems to be making mainly sickles and horseshoes."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG93_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG93_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG93 ;
    crm:P190_has_symbolic_content "Kowal urządził sobie miejsce pracy na cotygodniowym targu w Qaysar. Przed nim znajduje się małe kowadło wbite w ziemię. Obok znajdują się jego narzędzia, a na dole obrazka widać kuźnię, w której węgiel drzewny żarzy się dwoma miechami. Wydaje się, że wyrabia głównie sierpy i podkowy."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

