ga:EWA76_MG89_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG89 ;
    crm:P190_has_symbolic_content "Na skraju częściowo zalanej ulicy kupcy wystawiali swoje towary w dzień targowy. Oferta obejmuje zarówno migdały w lukrze, jak i trzonki do butów i łopat. Wzrok przyciągają malowane skrzynie, stojaki ścienne, stojaki na lampy i kołyska."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

