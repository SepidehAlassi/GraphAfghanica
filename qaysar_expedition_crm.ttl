ga:EWA76_MG79_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG79 ;
    crm:P190_has_symbolic_content "Ein vermutlich uzbekischer Händler sitzt in seinem Gemischtwarenladen in Reichweite der wichtigsten Artikel. Im Gegensatz zu den ‘fliegenden’ Händlern, die nur an den Markttagen am Strassenrand Waren anbieten, besitzt er eine stabile Balkenwaage und geeichte Gewichtssteine. Er scheint ein gebildeter Mann zu sein, der lesen und schreiben kann, denn vor ihm liegt eine Zeitschrift."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG79_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG79_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG79 ;
    crm:P190_has_symbolic_content "A presumably Uzbek merchant sits in his general store, within easy reach of the most important items. In contrast to the 'flying' traders, who only offer goods on the roadside on market days, it has a sturdy beam scale and calibrated weight stones. He seems to be an educated man who can read and write, because there is a magazine in front of him."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG79_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG79_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG79 ;
    crm:P190_has_symbolic_content "Przypuszczalnie uzbecki kupiec siedzi w swoim sklepie wielobranżowym, w zasięgu najważniejszych artykułów. W przeciwieństwie do \"latających\" handlarzy, którzy oferują towary na poboczu drogi tylko w dni targowe, ma solidną wagę belkową i skalibrowane kamienie wagowe. Wydaje się być człowiekiem wykształconym, który umie czytać i pisać, ponieważ ma przed sobą czasopismo."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG79_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

