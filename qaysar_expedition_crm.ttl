ga:EWA76_MG75_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG75 ;
    crm:P190_has_symbolic_content "Auf diesem Bild von einem weniger belebten Teil des Basars hat ein Händler seine Ware längs des Abwasserkanals in kleinen Stapeln deponiert. Es scheint sich um zusammengefaltete Stoffe oder Kleidungsstücke zu handeln. Wie auf den vorangehenden Fotos sieht man auch hier, dass – ebenfalls längs des Abwasserkanals – Nadelbäume oder Tamarisken wachsen."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG75_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG75_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG75 ;
    crm:P190_has_symbolic_content "In this picture of a less busy part of the bazaar, a vendor has deposited his goods in small piles along the sewer. They appear to be folded fabrics or garments. As in the previous photos, you can see that conifers or tamarisks are growing along the sewer."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG75_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG75_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG75 ;
    crm:P190_has_symbolic_content "Na tym zdjęciu mniej ruchliwej części bazaru sprzedawca złożył swoje towary w małych stosach wzdłuż kanału. Wydają się być złożonymi tkaninami lub odzieżą. Podobnie jak na poprzednich zdjęciach, widać, że wzdłuż kanału rosną drzewa iglaste lub tamaryszki."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG75_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
