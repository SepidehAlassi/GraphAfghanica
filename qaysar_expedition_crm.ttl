ga:EWA76_MG87_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG87 ;
    crm:P190_has_symbolic_content "Auf einem breiten, horizontalen Teppichknüpfstuhl kauern vier Personen nebeneinander. Ganz rechts eine Turkmenin mit der typischen hohen Haube; neben ihr ein Knabe und zwei Mädchen, die laut der Beschreibung von Marek Gawęcki Pashtunen sind und von der Turkmenin angelernt werden. Die Aufnahme entstand möglicherweise im Haus von Khoja Mahomat Amin am 14.8."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG87_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG87_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG87 ;
    crm:P190_has_symbolic_content "Four people huddle next to each other on a wide, horizontal carpet knotting chair. On the far right, a Turkmen woman with the typical high hood; next to her is a boy and two girls, who, according to Marek Gawęcki's description, are Pashtuns and are trained by the Turkmen. It is possible that this photo was taken in Khoja Mahomat Amin’s house on August 14."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG87_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG87_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG87 ;
    crm:P190_has_symbolic_content "Cztery osoby tłoczą się obok siebie na szerokim, poziomym krześle do wiązania dywanów. Po prawej turkmeńska kobieta z typowym wysokim kapturem; Obok niej znajduje się chłopiec i dwie dziewczynki, którzy według opisu Marka Gawęckiego są Pasztunami i są szkoleni przez Turkmenów."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

