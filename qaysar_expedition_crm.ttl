ga:EWA76_98_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_98 ;
    crm:P190_has_symbolic_content "Ein weiterer Schmied auf dem Wochenmarkt in Qaysar hat eine Tülle (rohrförmiges Teil eines Werkzeugs, in dem ein Stiel befestigt werden kann) hergestellt, die er nun mit Nieten an einem Schaufelblatt oder einer Pflugschar befestigt. Vor und neben ihm liegt sein Werkzeug und eine kleine Esse, in der durch den Knaben im Hintergrund mit zwei Blasebälgen die Holzkohle zum Glühen gebracht wird. Die beiden Kunden am rechten Bildrand sehen zu, wie Ihr Auftrag ausgeführt wird"@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_98_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_98_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_98 ;
    crm:P190_has_symbolic_content "Another blacksmith at the weekly market in Qaysar has made a grommet (tubular part of a tool in which a handle can be attached), which he now attaches to a shovel blade or ploughshare with rivets. In front of and next to him lie his tools and a small forge, in which the boy in the background makes the charcoal glow with two bellows. The two customers on the right side of the screen watch how their order is being executed."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_98_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_98_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_98 ;
    crm:P190_has_symbolic_content "Inny kowal na cotygodniowym targu w Qaysar wykonał dzióbek (rurkowatą część narzędzia, do której można przymocować uchwyt), który teraz mocuje nitami do ostrza łopaty lub lemiesza. Przed nim i obok niego leżą jego narzędzia i mała kuźnia, w której chłopiec w tle dwoma miechami sprawia, że węgiel drzewny płonie. Dwaj klienci po prawej stronie ekranu obserwują, jak realizowane jest ich zamówienie"@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_98_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

