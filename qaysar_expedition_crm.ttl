ga:EWA76_MG76_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG76 ;
    crm:P190_has_symbolic_content "Auf dem Dach einiger dukanha wurde ein bala khana (Oberhaus) errichtet. Da direkt von der Strasse eine steile Treppe hinaufführt, scheint es sich um ein Teehaus (chaikhana) zu handeln. Auch die Dekoration der Wandflächen deutet darauf hin. Durch die erhöhte Lage hofft man auf einen kühlenden Luftzug; auch bietet man den Gästen von der vorgelagerten offenen Terrasse einen Blick auf das Geschehen auf der Strasse."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG76_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG76_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG76 ;
    crm:P190_has_symbolic_content "A bala khana (upper house) was erected on the roof of some dukanha. Since a steep staircase leads up directly from the street, it seems to be a tea house (chaikhana). The decoration of the wall surfaces also indicates this. Due to the elevated location, it is hoped that there will be a cooling draught; guests are also offered a view of the action on the street from the open terrace in front."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG76_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG76_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG76 ;
    crm:P190_has_symbolic_content "Bala khana (górny dom) został wzniesiony na dachu niektórych dukanha. Ponieważ strome schody prowadzą bezpośrednio z ulicy, wydaje się, że jest to herbaciarnia (chaikhana). Wskazuje na to również dekoracja powierzchni ścian. Ze względu na położenie na wzniesieniu spodziewany jest przeciąg chłodzący; Goście mają również widok na ulicę z otwartego tarasu przed domem."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG76_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

