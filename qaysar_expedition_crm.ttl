ga:EWA76_MG81_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG81 ;
    crm:P190_has_symbolic_content "Stoffhändler gehören zu einer angeseheneren Gruppe von Kaufleuten, denn diese Sparte setzt ein ansehnliches Eigenkapital voraus. Deshalb sind es zumeist Familien-Unternehmen, in denen Vater und Sohn zusammenarbeiten. Stoffläden haben oft auch einen rückwärtigen Raum, in dem Kundinnen unbeobachtet bedient werden können. Da es hier um grössere Beträge geht, erhalten die Kunden üblicherweise einen Tee angeboten."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG81_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG81_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG81 ;
    crm:P190_has_symbolic_content "Cloth merchants belong to a more respectable group of merchants, because this branch requires a considerable amount of equity. That's why it's mostly family businesses in which father and son work together. Fabric shops often also have a room at the back where female customers can be served unobserved. Since larger amounts are involved, customers are usually offered a cup of tea."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG81_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG81_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG81 ;
    crm:P190_has_symbolic_content "Kupcy sukna należą do bardziej szanowanej grupy kupców, ponieważ ta gałąź wymaga znacznego kapitału własnego. Dlatego to głównie firmy rodzinne, w których ojciec i syn pracują razem. Sklepy z tkaninami często mają również pomieszczenie na zapleczu, w którym klienci mogą być obsługiwani niezauważeni. Ponieważ w grę wchodzą większe kwoty, klientom zwykle oferuje się filiżankę herbaty."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG81_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

