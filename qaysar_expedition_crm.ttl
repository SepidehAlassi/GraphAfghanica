ga:EWA76_MG84_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG84 ;
    crm:P190_has_symbolic_content "Aus alten Lastwagen-Reifen und Gummi-Schläuchen fertigt dieser Handwerker strapazierfähige Schuhe für die Feldarbeit. Aufwändiger gearbeitete Schuhe hängen an einer Stange über der Türe. An den Türflügeln hängen Gummi-‘Lassos’, die er als lange Spirale aus den Schläuchen geschnitten hat. Zur Unterhaltung hört er Musik-Kassetten auf seinem Transistor-Radio."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG84_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG84_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG84 ;
    crm:P190_has_symbolic_content "From old truck tires and rubber tubes, this craftsman makes durable shoes for field work. More elaborately crafted shoes hang on a pole above the door. Rubber 'lassos' hang from the door leaves, which he has cut out of the hoses in a long spiral. For entertainment, he listens to music cassettes on his transistor radio."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG84_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG84_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG84 ;
    crm:P190_has_symbolic_content "Ze starych opon ciężarowych i gumowych dętek ten rzemieślnik tworzy wytrzymałe buty do pracy w terenie. Bardziej misternie wykonane buty wiszą na słupie nad drzwiami. Ze skrzydeł drzwi zwisają gumowe \"lassa\", które wyciął z węży w długiej spirali. Dla rozrywki słucha kaset muzycznych w radiu tranzystorowym."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG84_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

