ga:EWA76_MG90_Description_de a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG90 ;
    crm:P190_has_symbolic_content "Ein dunkel gekleideter Mann mit schwarzem Turban hat auf einem Tuch sein Angebot ausgebreitet. Zentral ist ein aufklappbares Holzgestell mit Toilettenartikeln. Davor stehen kleine Fläschchen. Im Vordergrund sind geöffnete kleine Säcke aufgereiht. Vermutlich handelt er mit traditioneller Medizin und Heilkräutern."@de ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG90_Description_de_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG90_Description_en a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG90 ;
    crm:P190_has_symbolic_content "A dark-dressed man with black turban has spread out his offer on a cloth. Central is a hinged wooden rack with toiletries. In front of it are small bottles. In the foreground, small open bags are lined up. Presumably, he deals in traditional medicine and medicinal herbs."@en ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG90_Description_en_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

ga:EWA76_MG90_Description_pl a crm:E33_Linguistic_Object ;
    crm:P129_is_about ga:EWA76_MG90 ;
    crm:P190_has_symbolic_content "Ciemno ubrany mężczyzna w czarnym turbanie rozłożył swoją ofertę na płótnie. Centralnym elementem jest drewniany stojak na z zestawem kosmetyków. Przed nim znajdują się małe butelki. Na pierwszym planie ustawione są małe otwarte torby. Przypuszczalnie zajmuje się tradycyjną medycyną i ziołami leczniczymi."@pl ;
    crm:P2_has_type ga:Image_Description_Type .

ga:EWA76_MG90_Description_pl_Confidence a crm:E54_Dimension ;
    crm:P2_has_type ga:Confidence ;
    crm:P90_has_value 1.0 ;
    crm:P91_has_unit ga:Probability_Unit .

